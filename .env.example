# Public app URL used for every CTA (handled by src/lib/cta.ts).
PUBLIC_APP_URL=https://my.dailymood.me

# Public landing URL used for canonical + OG + hreflang alternates.
PUBLIC_SITE_URL=https://dailymood.me

# Google Analytics 4 measurement ID (G-XXXXXXXXXX).
# Loaded on every page load (PDPA informed-notice model — the banner notifies,
# tracking runs with anonymize_ip). Leave empty in development to disable GA.
PUBLIC_GA_ID=

# Google Ads conversion / remarketing tag ID (AW-XXXXXXXXX).
# Loaded alongside GA via the same gtag.js bootstrap. Disclosed in /cookies.
# Leave empty in development to disable Google Ads tracking.
PUBLIC_GADS_ID=
