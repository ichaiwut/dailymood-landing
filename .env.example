# Public app URL used for every CTA (handled by src/lib/cta.ts).
PUBLIC_APP_URL=https://my.dailymood.me

# Public landing URL used for canonical + OG + hreflang alternates.
PUBLIC_SITE_URL=https://dailymood.me

# Google Analytics 4 measurement ID (G-XXXXXXXXXX).
# Loaded only after the user clicks "Accept" on the cookie consent banner.
# Leave empty in development to disable GA entirely.
PUBLIC_GA_ID=
