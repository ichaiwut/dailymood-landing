# Railway sets $PORT at runtime; default to 8080 for local docker run.
{$PORT:8080} {
	root * /usr/share/caddy
	encode zstd gzip

	# Long-term cache for fingerprinted/static assets. Astro emits CSS/JS
	# with content hashes in their filenames, so immutable is safe.
	@assets path_regexp \.(png|jpg|jpeg|webp|gif|svg|ico|woff2?|css|js)$
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# HTML / XML / TXT should revalidate frequently — they don't have
	# fingerprints and updates need to roll out fast.
	@html path *.html /
	header @html Cache-Control "public, max-age=300, must-revalidate"

	# Standard security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Hide the default Caddy server header.
		-Server
	}

	file_server

	# Astro builds /privacy/index.html, /en/privacy/index.html, etc.
	# Caddy's file_server already serves index.html inside directories;
	# this handles 404s gracefully.
	handle_errors {
		respond "Not Found" 404
	}

	# Built-in healthcheck endpoint Railway can hit.
	respond /healthz "ok" 200
}
