---
import Logo from './Logo.astro';
import MoodFace from './MoodFace.astro';
import { type Locale, getMessages } from '@/lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const m = getMessages(locale).landing.mockup;

const moods = [
  { id: 'great', color: 'var(--peach)' },
  { id: 'good', color: 'var(--yellow)' },
  { id: 'okay', color: 'var(--mint)' },
  { id: 'meh', color: 'var(--lavender)' },
  { id: 'bad', color: 'var(--blue)' },
  { id: 'awful', color: 'var(--purple)' },
  { id: 'calm', color: '#B9D6F2' },
] as const;

const palette = ['var(--peach)', 'var(--yellow)', 'var(--mint)', 'var(--lavender)', 'var(--blue)', 'var(--purple)'];
const sparkX = [0, 28, 56, 84, 112, 140, 168, 200];
const sparkY = [26, 22, 25, 18, 20, 14, 10, 6];
---

<div
  style="border-radius:18px;background:#fff;box-shadow:0 40px 80px -20px rgba(70,32,100,.25),0 20px 40px -20px rgba(0,0,0,.15);overflow:hidden;border:1px solid rgba(0,0,0,.05)"
>
  <!-- chrome -->
  <div
    style="height:38px;background:#F4EEE6;display:flex;align-items:center;padding:0 14px;gap:10px;border-bottom:1px solid rgba(0,0,0,.05)"
  >
    <div style="display:flex;gap:6px">
      <span style="width:11px;height:11px;border-radius:50%;background:#FF6058"></span>
      <span style="width:11px;height:11px;border-radius:50%;background:#FEBC2E"></span>
      <span style="width:11px;height:11px;border-radius:50%;background:#29C840"></span>
    </div>
    <div
      style="flex:1;height:22px;background:#fff;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--ink-3);font-weight:600;max-width:280px;margin:0 auto"
    >
      <span style="margin-right:6px;font-size:9px">🔒</span>
      dailymood.me/today
    </div>
    <div style="width:50px"></div>
  </div>

  <!-- app body -->
  <div style="background:var(--bg);padding:22px;font-family:var(--font)">
    <!-- topbar -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
      <div style="display:flex;align-items:center">
        <Logo size={22} />
      </div>
      <div style="display:flex;gap:18px;font-size:12px;font-weight:600;color:var(--ink-2)">
        <span style="color:var(--ink)">{m.topbarToday}</span>
        <span>{m.topbarCalendar}</span>
        <span>{m.topbarStats}</span>
        <span>{m.topbarInsights}</span>
      </div>
      <div
        style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--peach),var(--purple))"
      ></div>
    </div>

    <!-- hero greeting -->
    <div
      style="border-radius:18px;padding:18px 20px;background:linear-gradient(135deg,#F8EDEB 0%,#E9DEF6 100%);margin-bottom:14px;position:relative;overflow:hidden"
    >
      <div
        style="font-size:11px;font-weight:700;color:var(--purple-strong);text-transform:uppercase;letter-spacing:.04em"
      >
        {m.greeting}
      </div>
      <div style="font-size:19px;font-weight:800;margin-top:6px;line-height:1.15">
        {m.question}
      </div>
      <div style="display:flex;gap:7px;margin-top:12px">
        {
          moods.map((mood, i) => (
            <div style="flex:1">
              <div
                style={`width:100%;aspect-ratio:1;border-radius:50%;background:${
                  i === 0 ? mood.color : '#fff'
                };border:${i === 0 ? 'none' : '1px solid rgba(0,0,0,.05)'};display:flex;align-items:center;justify-content:center;box-shadow:${
                  i === 0 ? '0 6px 14px -2px rgba(252,164,91,.55)' : 'none'
                }`}
              >
                <MoodFace face={mood.id} size={28} bg="transparent" />
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- two-col: AI summary + mini cal -->
    <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:12px">
      <!-- AI summary -->
      <div
        class="card"
        style="padding:16px;border-radius:16px;box-shadow:none;border:1px solid var(--hairline)"
      >
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px">
          <span style="font-size:10px;font-weight:800;color:var(--purple-strong);letter-spacing:.06em">
            {m.aiSummaryTag}
          </span>
          <span style="font-size:9px;color:var(--ink-3)">· {m.aiSummaryPeriod}</span>
        </div>
        <div style="font-size:12px;line-height:1.55;color:var(--ink-2)">
          {m.aiSummary1} <b style="color:var(--ink)">{m.aiSummary1bold}</b> {m.aiSummary2}
          <b style="color:var(--ink)">{m.aiSummary2bold}</b>. {m.aiSummary3}
        </div>
        <svg
          viewBox="0 0 200 36"
          style="width:100%;height:32px;margin-top:10px"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="dm-spark" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#A673F1" stop-opacity=".3"></stop>
              <stop offset="1" stop-color="#A673F1" stop-opacity="0"></stop>
            </linearGradient>
          </defs>
          <path
            d="M 0 26 L 28 22 L 56 25 L 84 18 L 112 20 L 140 14 L 168 10 L 200 6 L 200 36 L 0 36 Z"
            fill="url(#dm-spark)"></path>
          <path
            d="M 0 26 L 28 22 L 56 25 L 84 18 L 112 20 L 140 14 L 168 10 L 200 6"
            stroke="#A673F1"
            stroke-width="1.8"
            fill="none"
            stroke-linecap="round"></path>
          {sparkX.map((x, i) => (
            <circle cx={x} cy={sparkY[i]} r="2.2" fill="#fff" stroke="#A673F1" stroke-width="1.4" />
          ))}
        </svg>
      </div>

      <!-- mini calendar -->
      <div
        class="card"
        style="padding:12px;border-radius:16px;box-shadow:none;border:1px solid var(--hairline)"
      >
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <span style="font-size:11px;font-weight:800">{m.calMonth}</span>
          <span style="font-size:9px;color:var(--ink-3)">12 / 31</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px">
          {
            Array.from({ length: 31 }).map((_, i) => {
              const filled = i < 12;
              const c = filled ? palette[(i * 3) % palette.length] : 'transparent';
              return (
                <div
                  style={`aspect-ratio:1;border-radius:4px;background:${
                    filled ? c : '#F5F1EB'
                  };${i === 11 ? 'border:1.5px solid var(--ink)' : ''}`}
                />
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</div>
