---
import CheckCircle from './CheckCircle.astro';
import { type Locale, getMessages } from '@/lib/i18n';
import { loginHref } from '@/lib/cta';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const p = getMessages(locale).landing.pricing;
const freeFeats = p.freeFeats as string[];
const proFeats = p.proFeats as string[];
---

<section id="pricing" class="section">
  <div class="container">
    <div style="text-align:center;max-width:680px;margin:0 auto 56px">
      <span class="eyebrow"><span class="dot"></span> {p.eyebrow}</span>
      <h2 class="h-display" style="font-size:clamp(32px, 4.5vw, 52px);margin:22px 0 14px">
        {p.title}
      </h2>
      <p style="font-size:18px;color:var(--ink-2)">{p.sub}</p>
    </div>

    <div
      class="l-pricing"
      style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:920px;margin:0 auto"
    >
      <!-- Free -->
      <div
        style="padding:36px;border-radius:24px;background:#fff;border:1.5px solid var(--rule);display:flex;flex-direction:column;gap:22px"
      >
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.04em">
            {p.freeName}
          </div>
          <div style="display:flex;align-items:baseline;gap:8px;margin-top:8px">
            <span class="h-display" style="font-size:56px">{p.freePrice}</span>
            <span style="color:var(--ink-3);font-size:15px">{p.freePer}</span>
          </div>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;flex:1">
          {
            freeFeats.map((feat) => (
              <li style="display:flex;align-items:flex-start;gap:10px;font-size:15px">
                <CheckCircle />
                <span>{feat}</span>
              </li>
            ))
          }
        </ul>
        <a href={loginHref()} class="btn btn-ghost" style="width:100%">{p.freeCta}</a>
      </div>

      <!-- Pro -->
      <div
        style="padding:36px;border-radius:24px;position:relative;background:linear-gradient(155deg, #2A1F33 0%, #1A1320 100%);color:#fff;display:flex;flex-direction:column;gap:22px;box-shadow:0 30px 60px -20px rgba(166,115,241,.35)"
      >
        <div
          style="position:absolute;top:-12px;right:32px;padding:6px 14px;border-radius:100px;background:var(--peach);color:#fff;font-size:12px;font-weight:800;letter-spacing:.04em;text-transform:uppercase"
        >
          {p.proBadge}
        </div>
        <div>
          <div style="font-size:14px;font-weight:700;color:#D9C2FF;text-transform:uppercase;letter-spacing:.04em">
            {p.proName}
          </div>
          <div style="display:flex;align-items:baseline;gap:8px;margin-top:8px">
            <span class="h-display" style="font-size:56px;color:#fff">{p.proPrice}</span>
            <span style="color:rgba(255,255,255,.6);font-size:14px">{p.proPer}</span>
          </div>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;flex:1">
          {
            proFeats.map((feat) => (
              <li style="display:flex;align-items:flex-start;gap:10px;font-size:15px;color:rgba(255,255,255,.92)">
                <span style="flex-shrink:0;margin-top:2px">
                  <CheckCircle fill="var(--peach)" />
                </span>
                <span>{feat}</span>
              </li>
            ))
          }
        </ul>
        <a href={loginHref()} class="btn btn-peach" style="width:100%">{p.proCta}</a>
      </div>
    </div>
  </div>
</section>
