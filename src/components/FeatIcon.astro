---
interface Props {
  i: number;
  stroke: string;
}
const { i, stroke } = Astro.props;
const sw = 1.8;
---

<svg width="26" height="26" viewBox="0 0 26 26" aria-hidden="true">
  {
    i === 0 && (
      <>
        <circle cx="13" cy="13" r="8" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <circle cx="10" cy="11" r=".8" fill={stroke} />
        <circle cx="16" cy="11" r=".8" fill={stroke} />
        <path d="M 9 15 Q 13 18 17 15" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
      </>
    )
  }
  {
    i === 1 && (
      <>
        <rect x="11" y="3" width="4" height="11" rx="2" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M 7 11 V 12 A 6 6 0 0 0 19 12 V 11" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <line x1="13" y1="18" x2="13" y2="22" stroke={stroke} stroke-width={sw} stroke-linecap="round" />
        <line x1="10" y1="22" x2="16" y2="22" stroke={stroke} stroke-width={sw} stroke-linecap="round" />
