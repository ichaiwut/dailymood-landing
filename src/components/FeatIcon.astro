      </>
    )
  }
  {
    i === 4 && (
      <>
        <path d="M 4 7 H 19 V 17 L 15 17 L 12 20 L 9 17 H 4 Z" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
