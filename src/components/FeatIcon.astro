      </>
    )
  }
  {
    i === 8 && (
      <>
        <rect x="4" y="4" width="8" height="8" rx="2" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="14" y="4" width="8" height="8" rx="2" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="4" y="14" width="8" height="8" rx="2" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="14" y="14" width="8" height="8" rx="2" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
