        <line x1="7" y1="4" x2="7" y2="7" stroke={stroke} stroke-width={sw} stroke-linecap="round" />
        <line x1="13" y1="4" x2="13" y2="7" stroke={stroke} stroke-width={sw} stroke-linecap="round" />
