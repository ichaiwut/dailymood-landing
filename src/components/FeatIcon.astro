        <path d="M 15 9 L 15.3 10 L 16 10.3 L 15.3 10.6 L 15 11.5 L 14.7 10.6 L 14 10.3 L 14.7 10 Z" fill={stroke} />
      </>
    )
  }
  {
    i === 5 && (
      <>
        <polyline points="3,19 8,14 12,16 17,9" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="round" stroke-linejoin="round" />
