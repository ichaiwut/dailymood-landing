---
import { type Locale, getMessages } from '@/lib/i18n';
import { loginHref } from '@/lib/cta';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = getMessages(locale).landing.cta;
---

<section id="cta" class="section" style="padding-bottom:80px">
  <div class="container">
    <div
      style="border-radius:32px;padding:72px 48px;background:linear-gradient(135deg, var(--peach) 0%, #F49EAB 45%, var(--purple) 100%);color:#fff;text-align:center;position:relative;overflow:clip;overflow-clip-margin:24px"
    >
      <div aria-hidden="true" style="position:absolute;top:30px;left:60px;font-size:32px;opacity:.85;transform:rotate(-12deg)">✨</div>
      <div aria-hidden="true" style="position:absolute;bottom:40px;right:70px;font-size:36px;opacity:.85;transform:rotate(15deg)">🌿</div>
      <div aria-hidden="true" style="position:absolute;top:50px;right:90px;font-size:26px;opacity:.8;transform:rotate(8deg)">☕</div>
      <div aria-hidden="true" style="position:absolute;bottom:50px;left:100px;font-size:30px;opacity:.8;transform:rotate(-8deg)">📓</div>

      <h2
        class="h-display"
        style="font-size:clamp(34px, 5vw, 64px);color:#fff;max-width:760px;margin:0 auto 18px"
      >
        {c.title}
      </h2>
      <p style="font-size:19px;color:rgba(255,255,255,.9);max-width:540px;margin:0 auto 32px">
        {c.sub}
      </p>
      <a
        href={loginHref()}
        class="btn"
        style="background:#fff;color:var(--ink);height:60px;padding:0 32px;font-size:17px;box-shadow:0 16px 40px -12px rgba(0,0,0,.3)"
      >
        {c.btn} →
      </a>
    </div>
  </div>
</section>
