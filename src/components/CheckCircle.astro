---
interface Props {
  size?: number;
  fill?: string;
}
const { size = 16, fill = 'var(--mint)' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 16 16"
  aria-hidden="true"
  style="flex-shrink:0"
>
  <circle cx="8" cy="8" r="8" fill={fill}></circle>
  <path
    d="M 4.5 8.5 L 7 11 L 11.5 5.5"
    stroke="#1A1320"
    stroke-width="1.8"
    fill="none"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>
